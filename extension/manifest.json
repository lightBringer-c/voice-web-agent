{
  "manifest_version": 3,
  "name": "Voice Web Agent",
  "version": "1.0",
  "description": "Voice assistant for web navigation",
  "permissions": ["activeTab","scripting"],
  "host_permissions": ["<all_urls>"],
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ]
}